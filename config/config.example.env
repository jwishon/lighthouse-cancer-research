# Lighthouse configuration — copy this file to config/.env and fill it in.
# config/.env is gitignored and must never be committed.

# --- AI model (default: Anthropic Claude) ---
# Used to summarize and rank findings. Get a key from your AI provider.
ANTHROPIC_API_KEY=
LIGHTHOUSE_MODEL_SYNTHESIS=claude-sonnet-4-6

# --- What to research ---
# Normally Lighthouse reads the cancer type from data/patient-profile.md.
# Set these only if you want to override the profile.
LIGHTHOUSE_CONDITION=
LIGHTHOUSE_LOCATION=

# --- Research sources ---
# Optional, free: raises PubMed rate limits. Leave blank for the public limit.
NCBI_API_KEY=
# Optional: enables broader web/scholarly search (conferences, news). Leave
# blank to skip Exa entirely — Lighthouse works fine without it.
EXA_API_KEY=

# --- Digest delivery (email) ---
# Use any SMTP account, or a service like Resend. Leave SMTP_HOST blank to
# write digests to disk only (data/digests/) with no email.
SMTP_HOST=
SMTP_PO